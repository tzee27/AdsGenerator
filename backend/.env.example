APP_NAME=AdsGenerator API
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1

# Target market for live-context gathering
AREA=Malaysia

# Z.A.I — one API key for GLM chat (text + web search) and GLM-Image (same host:
# https://api.z.ai/api/paas/v4 — chat: /chat/completions, images: /images/generations).
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_CHAT_MODEL=glm-5.1
ZAI_CHAT_TIMEOUT_SECONDS=180
ZAI_WEB_SEARCH_ENABLED=true

ZAI_IMAGE_MODEL=glm-image
ZAI_IMAGE_QUALITY=hd
ZAI_IMAGE_TIMEOUT_SECONDS=90

# Deprecated: if ZAI_API_KEY is empty, ILMU_API_KEY is still read for migration only.
ILMU_API_KEY=

# CORS — comma-separated origins allowed to call this API. The defaults cover
# Vite's standard dev (5173) and preview (4173) ports. Add your prod origin too.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
# Optional: allow all Vercel preview/prod hosts (credentials + wildcard * is invalid, so use regex).
# CORS_ALLOW_ORIGIN_REGEX=https://.*\.vercel\.app

# Legacy / Firebase placeholders
AI_PROVIDER=
AI_MODEL=
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=
